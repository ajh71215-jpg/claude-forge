# Locked-down Windows environment: cmd.exe and powershell.exe are blocked.
# Point npm's script runner at Git Bash so `npm run <script>` works from the
# terminal without needing cmd.exe. The node-based script paths in package.json
# scripts are the primary bypass, but this covers any script that still uses a
# bare binary name.
script-shell=C:\\Users\\CKIRUser\\PortableGit\\bin\\bash.exe
