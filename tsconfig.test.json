{
  "//": "Compiles the pure renderer lib modules + their unit tests to CommonJS so `npm test` can run them headlessly with node:test (no electron, no DOM, no SDK). Mirrors tsconfig.selftest.json.",
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022", "DOM"],
    "ignoreDeprecations": "6.0",
    "rootDir": ".",
    "outDir": "out-test",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "noEmit": false
  },
  "include": [
    "test/**/*.ts",
    "src/renderer/src/lib/export.ts",
    "src/renderer/src/lib/blocks.ts",
    "src/renderer/src/lib/format.ts"
  ]
}
